{
  "name": "5elements-chatbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:widget && next build",
    "build:widget": "npm run build:widget:css && npm run build:widget:js",
    "build:widget:css": "tailwindcss -i styles/widget.css -o public/chatbot.css --config tailwind-widget.config.js --minify",
    "build:widget:js": "tsup",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@langchain/core": "^0.2.18",
    "@langchain/openai": "^0.2.5",
    "axios": "^1.6.0",
    "langchain": "^0.2.16",
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.4.1",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
