# ── Required ─────────────────────────────────────────────────────────────────

# DeepSeek LLM API key — get free at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Owner email — receives escalation emails for business inquiries
OWNER_EMAIL=owner@5elements-sports.com

# Resend email API key — get free at https://resend.com (100 emails/day free)
RESEND_API_KEY=re-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ──────────────────────────────────────────────────────────────────

# Custom "From" address for escalation emails.
# MUST be a domain verified in your Resend account.
# Default (if not set): onboarding@resend.dev  (Resend's sandbox sender)
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# Only needed if you expose the chat API from a SEPARATE domain (not same-origin)
# NEXT_PUBLIC_API_URL=https://your-chatbot.vercel.app
